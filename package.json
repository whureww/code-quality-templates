{
  "name": "mr-sliy",
  "version": "2.2.14",
  "description": "Mr.Sliy - 基于Tree-sitter与RAG的多语言代码优化智能体",
  "main": "src/agent.js",
  "bin": {
    "mr-sliy": "src/agent.js",
    "sliy": "src/agent.js"
  },
  "files": [
    "src/",
    "database/schema.sql",
    "database/init.js",
    "database/seed.js",
    "scripts/",
    "data/knowledge-export.json",
    ".env.example"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "start": "node src/agent.js",
    "agent": "node src/agent.js",
    "server": "node src/index.js",
    "dev": "nodemon src/agent.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "init": "node database/init.js",
    "seed": "node database/seed.js",
    "setup": "npm run init && npm run seed",
    "download-wasm": "node scripts/download-tree-sitter.js"
  },
  "keywords": [
    "ast",
    "code-analysis",
    "tree-sitter",
    "rag",
    "code-optimization",
    "ai",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.1",
    "better-sqlite3": "^9.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "mysql2": "^3.22.5",
    "tree-sitter-wasms": "^0.1.13",
    "uuid": "^9.0.1",
    "web-tree-sitter": "^0.20.8",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
