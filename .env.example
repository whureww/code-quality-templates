# ==================== 服务配置 ====================
# 服务端口
PORT=3000
# 运行环境: development | production | test
NODE_ENV=development
# 服务主机地址
HOST=localhost

# ==================== 数据库配置 ====================
# SQLite数据库文件路径
DB_PATH=./database/code_optimizer.db
# 数据库连接池最大连接数
DB_POOL_MAX=10
# 数据库连接池最小连接数
DB_POOL_MIN=2

# ==================== MySQL配置（云端知识库同步，可选） ====================
# 是否启用MySQL云同步: true | false
MYSQL_ENABLED=false
# MySQL主机地址
MYSQL_HOST=
# MySQL端口
MYSQL_PORT=3306
# MySQL用户名
MYSQL_USER=
# MySQL密码
MYSQL_PASSWORD=
# MySQL数据库名
MYSQL_DATABASE=code_optimizer
# MySQL连接池最大连接数
MYSQL_CONNECTION_LIMIT=10
# 启动时自动同步: true | false
MYSQL_SYNC_ON_STARTUP=true

# ==================== AI配置（在线模式） ====================
# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Claude (Anthropic)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229

# Ollama (本地大模型)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=codellama

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_DEPLOYMENT_NAME=gpt-4

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# 阿里通义千问
TONGYI_API_KEY=
TONGYI_MODEL=qwen-plus

# 字节豆包
DOUBAO_API_KEY=
DOUBAO_MODEL=Doubao-7B

# 百度文心一言
WENXIN_API_KEY=
WENXIN_SECRET_KEY=
WENXIN_MODEL=ernie-3.5

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 智谱AI (ChatGLM)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4

# Moonshot AI (Kimi)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# AI调用超时时间（毫秒）
AI_TIMEOUT=30000
# AI最大输出token数
AI_MAX_TOKENS=2000
# AI温度参数 (0-1)
AI_TEMPERATURE=0.7

# ==================== AST扫描配置 ====================
# 最大文件大小（字节）
MAX_FILE_SIZE=1048576
# 扫描超时时间（毫秒）
SCAN_TIMEOUT=60000
# 是否启用并行扫描
ENABLE_PARALLEL_SCAN=true
# 并行扫描最大并发数
MAX_PARALLEL_JOBS=4
# 扫描文件扩展名（逗号分隔）
SCAN_EXTENSIONS=.js,.ts,.jsx,.tsx,.py,.java,.go,.rs
# 排除目录（逗号分隔）
EXCLUDE_DIRS=node_modules,dist,build,out,.git,coverage
# 排除文件（逗号分隔）
EXCLUDE_FILES=min.js,min.css,.d.ts

# ==================== 检测规则配置 ====================
DETECT_UNUSED_VARIABLES=true
DETECT_UNUSED_IMPORTS=true
DETECT_UNUSED_FUNCTIONS=true
DETECT_MAGIC_NUMBERS=true
MAX_FUNCTION_LINES=50
MAX_CYCLOMATIC_COMPLEXITY=10
MAX_NESTING_DEPTH=4
ENABLE_DEEP_NESTING_CHECK=true
ENABLE_NULL_CHECK=true
ENABLE_CONSOLE_LOG_CHECK=true
ENABLE_DUPLICATE_CODE_CHECK=true
ENABLE_COMMENT_CHECK=true

# ==================== 日志配置 ====================
# 日志级别: error | warn | info | debug
LOG_LEVEL=warn
# 日志文件路径
LOG_FILE=./logs/app.log
# 单个日志文件最大大小（字节）
LOG_MAX_SIZE=5242880
# 最大日志文件数量
LOG_MAX_FILES=5

# ==================== CORS配置 ====================
# 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:1420

# ==================== 速率限制 ====================
# API速率限制（每15分钟请求数）
RATE_LIMIT_MAX=100
